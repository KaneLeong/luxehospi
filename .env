# ─── Environment Variables ───────────────────────────────────────────
# Copy this file to .env.development or .env.production and adjust values.

# API
VITE_API_BASE_URL=/api
# Set to "false" to hit real backend; anything else keeps mock mode.
VITE_API_MOCK=true

# Site URL (used for SEO canonical / OG tags / JSON-LD)
VITE_SITE_URL=https://luxehospi.com
